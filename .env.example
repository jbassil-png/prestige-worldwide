# ── Supabase ──────────────────────────────────────────────────────────────────
# Get these from your Supabase project dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Plaid ─────────────────────────────────────────────────────────────────────
# Get these from https://dashboard.plaid.com
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox   # sandbox | development | production

# ── N8N ───────────────────────────────────────────────────────────────────────
# Webhook URLs for n8n workflows
# Example: http://localhost:5678/webhook/plan/generate or https://your.n8n.cloud/webhook/...
N8N_WEBHOOK_URL=
N8N_CHAT_WEBHOOK_URL=
# API token for n8n to authenticate callbacks to Next.js (optional but recommended)
N8N_API_TOKEN=

# ── Alpha Vantage ─────────────────────────────────────────────────────────────
# Get your free API key at https://www.alphavantage.co/support/#api-key
# Used by n8n workflows to fetch market data (S&P 500, bond yields, etc.)
ALPHA_VANTAGE_API_KEY=

# ── OpenRouter ────────────────────────────────────────────────────────────────
# Used as fallback when N8N is not configured, and for /api/insight + /api/news
# Get your key at https://openrouter.ai/keys
OPENROUTER_API_KEY=
# Model used for /api/chat fallback (defaults to claude-3.5-haiku for cost/speed)
OPENROUTER_MODEL=anthropic/claude-3.5-haiku

# ── Resend ────────────────────────────────────────────────────────────────────
# Get your key at https://resend.com/api-keys
# Also add to Supabase: Project Settings → Authentication → SMTP Settings
#   Host: smtp.resend.com | Port: 465 | Username: resend | Password: <your key>
RESEND_API_KEY=

# ── Exchange rates ────────────────────────────────────────────────────────────
# Free tier available at https://www.exchangerate-api.com
# If not set, the dashboard currency toggle uses hardcoded approximate rates
FX_API_KEY=
