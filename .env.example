# ── Supabase ──────────────────────────────────────────────────────────────────
# Get these from your Supabase project dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Plaid ─────────────────────────────────────────────────────────────────────
# Get these from https://dashboard.plaid.com
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox   # sandbox | development | production
# AES-256-GCM key for encrypting Plaid access tokens at rest.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
PLAID_TOKEN_ENCRYPTION_KEY=

# ── App URL ───────────────────────────────────────────────────────────────────
# Used for server-to-server internal API calls (e.g. profile → plan)
# Set to your production URL in Vercel: https://your-app.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Alpha Vantage ─────────────────────────────────────────────────────────────
# Get your free API key at https://www.alphavantage.co/support/#api-key
# Used by /api/insight and /api/news to fetch market data
ALPHA_VANTAGE_API_KEY=

# ── OpenRouter ────────────────────────────────────────────────────────────────
# Powers /api/chat, /api/plan/chat, /api/ai-proxy, /api/insight, and /api/news
# Get your key at https://openrouter.ai/keys
OPENROUTER_API_KEY=
# Model used for chat/plan responses (defaults to claude-3.5-haiku for cost/speed)
OPENROUTER_MODEL=anthropic/claude-3.5-haiku

# ── Resend ────────────────────────────────────────────────────────────────────
# Get your key at https://resend.com/api-keys
# Also add to Supabase: Project Settings → Authentication → SMTP Settings
#   Host: smtp.resend.com | Port: 465 | Username: resend | Password: <your key>
RESEND_API_KEY=

# ── Exchange rates ────────────────────────────────────────────────────────────
# Free tier available at https://www.exchangerate-api.com
# If not set, the dashboard currency toggle uses hardcoded approximate rates
FX_API_KEY=

# ── PostHog Analytics ─────────────────────────────────────────────────────────
# Get your key at https://app.posthog.com (free tier: 1M events/month)
# Used for tracking key user actions (sign-ups, plan generation, chat, etc.)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
